rules_version = '2';

// Lebenslauf-Uploads: nur Anlegen erlaubt (max. 10 MB, nur PDF/JPG/PNG).
// Lesen ausschließlich über Konsole/Admin-SDK.
service firebase.storage {
  match /b/{bucket}/o {

    match /bewerbungen/{bewerbungId}/{dateiName} {
      allow create: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/jpeg|image/png');
      allow read, update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
